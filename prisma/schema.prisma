generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String

  tasks         Task[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Task {
  id            String     @id @default(uuid())

  title         String
  description   String?

  status        TaskStatus @default(TODO)

  userId        String

  user          User @relation(
    fields: [userId],
    references: [id]
  )

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}